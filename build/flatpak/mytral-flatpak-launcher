# MyTraL Flatpak launcher
#
# Sets the desktop incarnation environment and starts MyTraL.
#   * flaskwebgui is not bundled in the Flatpak,
#     so run_desktop takes its "server + browser mode"
#   * fallback: it runs the Flask server inside the sandbox and opens the UI
#     in the host's default browser via the XDG OpenURI portal (webbrowser -> xdg-open).
export MYTRAL_INCARNATION=DESKTOP
export MYTRAL_USER_REGISTRATION=true
export MYTRAL_ENABLE_CACHE=true
# store data/config in the shared standard location:
#   ~/.local/share/mytral
#   ~/.config/mytral
# Flatpak grants only the mytral subdirs via --filesystem=xdg-{data,config}/mytral.
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CONFIG_HOME="$HOME/.config"
exec mytral-desktop "$@"
