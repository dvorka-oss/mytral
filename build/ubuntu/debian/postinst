#!/bin/sh
set -e

# MyTraL requires Python 3.12, which most Ubuntu releases do not ship as the
# system interpreter. Instead of depending on the system Python, uv is used to
# provision a self-contained Python 3.12 under /opt/mytral so that MyTraL runs
# identically on every release.

PREFIX=/opt/mytral
VENV=${PREFIX}/venv
UV=${PREFIX}/bin/uv
WHEEL=$(find "${PREFIX}" -name "mytral-*.whl" | head -1)
REQUIREMENTS=${PREFIX}/requirements.txt

# pinned uv release
UV_VERSION=0.7.8

case "$1" in
    configure)
        # map dpkg architecture to the uv release triple
        case "$(dpkg --print-architecture)" in
            amd64) UV_ARCH=x86_64-unknown-linux-gnu ;;
            arm64) UV_ARCH=aarch64-unknown-linux-gnu ;;
            *)
                echo "mytral: unsupported architecture $(dpkg --print-architecture)" >&2
                exit 1
                ;;
        esac

        echo "mytral: downloading uv ${UV_VERSION}..."
        mkdir -p "${PREFIX}/bin"
        curl -LsSf \
            "https://github.com/astral-sh/uv/releases/download/${UV_VERSION}/uv-${UV_ARCH}.tar.gz" \
            | tar -xz -C "${PREFIX}/bin" --strip-components=1 "uv-${UV_ARCH}/uv"

        # keep the managed Python and uv cache self-contained under /opt/mytral
        export UV_PYTHON_INSTALL_DIR="${PREFIX}/python"
        export UV_CACHE_DIR="${PREFIX}/.cache"

        echo "mytral: provisioning Python 3.12 (this may take a minute)..."
        "${UV}" venv --python 3.12 "${VENV}"

        echo "mytral: installing dependencies..."
        "${UV}" pip install --python "${VENV}/bin/python" \
            -r "${REQUIREMENTS}" "${WHEEL}"

        # cache is only needed during installation
        rm -rf "${UV_CACHE_DIR}"
        ;;
esac

#DEBHELPER#

exit 0
