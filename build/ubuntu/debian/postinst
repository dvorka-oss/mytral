#!/bin/sh
set -e

VENV=/opt/mytral/venv
WHEEL=$(find /opt/mytral -name "mytral-*.whl" | head -1)
REQUIREMENTS=/opt/mytral/requirements.txt

case "$1" in
    configure)
        echo "mytral: creating isolated virtual environment at ${VENV}..."
        python3 -m venv "${VENV}"
        echo "mytral: installing dependencies (this may take a minute)..."
        "${VENV}/bin/pip" install --quiet \
            -r "${REQUIREMENTS}" "${WHEEL}" || \
            echo "WARNING: pip install failed. Run manually: ${VENV}/bin/pip install -r ${REQUIREMENTS} ${WHEEL}"
        ;;
esac

#DEBHELPER#

exit 0
