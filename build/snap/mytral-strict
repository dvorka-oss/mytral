# Strict confinement launcher: under strict the snap runs inside the core24 runtime
# mount namespace, so the bundled python3.12 finds core24's glibc normally. No ld.so
# gymnastics are needed here (that hack is classic-only - see mytral-wrapper).
export PYTHONHOME="$SNAP/usr"
exec "$SNAP/usr/bin/python3.12" "$SNAP/bin/mytral-desktop" "$@"
